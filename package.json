{
  "name": "react-gamebaby",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "A Brick Game 9999-in-1 emulator built with React, and a reference implementation of end-to-end AI-assisted engineering practices.",
  "keywords": [
    "brick-game",
    "retro",
    "emulator",
    "react",
    "typescript",
    "reinforcement-learning",
    "ai-engineering"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flyerH/react-gamebaby.git"
  },
  "bugs": {
    "url": "https://github.com/flyerH/react-gamebaby/issues"
  },
  "homepage": "https://github.com/flyerH/react-gamebaby#readme",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "train": "tsx src/ai/train.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "echarts": "^6.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tensorflow/tfjs-node"
    ]
  }
}
